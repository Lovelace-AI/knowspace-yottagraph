# Skills copied from npm packages at install time (not committed).
# Local skills (not from npm) must be explicitly un-ignored below.
skills/*
!skills/aether/
!skills/elemental-mcp-patterns/

# Bundled instruction files (generated by scripts/publish-instructions.sh from commands/, skills/)
packages/aether-instructions/commands/
packages/aether-instructions/skills/

# Node dependencies
node_modules
.nuxt

.output

# Environment file
.env
.env.local
.env.*.local
.env.production
.env.development
.env.preview

# Commercial fonts (FK Grotesk) installed locally for dev only.
# See public/fonts/README.md for setup. Production hosting: TBD.
public/fonts/*.otf
public/fonts/*.woff
public/fonts/*.woff2
public/fonts/*.ttf
# Generated at build time by scripts/build-fonts-css.ts based on which
# font files exist in public/fonts/. Do not edit by hand.
assets/fonts.generated.css
# Environment files to keep! These are templates or use env vars, not secrets.
# .env.example - template
# .npmrc - uses ${NPM_TOKEN}

# Vercel project config (created by `vercel link`, unique per user)
.vercel/

# Broadchurch tenant config (created by /broadchurch_setup, may contain project-specific settings)
broadchurch.yaml

# Python virtual environments (for agents and MCP servers)
agents/.venv/
agents/*/.venv/
mcp-servers/*/.venv/
__pycache__/
*.pyc
*.egg-info/
.pytest_cache/

# Local Notion exports staged for import — never committed; uploaded via Import Center.
import/

# Generated API clients (legacy, can be removed)
composables/generated/
query/api/

# Avatar cache
.cache/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Platform-specific
.DS_Store
Thumbs.db
.vercel
